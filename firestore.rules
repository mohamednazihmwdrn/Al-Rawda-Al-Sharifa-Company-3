rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Permit read and write to the synchronization state document
    match /sync/{syncId} {
      allow read, write: if true;
    }
  }
}
